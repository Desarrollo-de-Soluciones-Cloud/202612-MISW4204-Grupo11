# Puerto del API (por defecto :8080)
HTTP_ADDR=:8080

# Si no defines DATABASE_URL, el programa usa por defecto:
# postgres://app:app@127.0.0.1:5432/app?sslmode=disable
# (útil con: docker compose up postgres)
#
# En docker-compose el servicio "api" ya define DATABASE_URL hacia el host "postgres".
# DATABASE_URL=
